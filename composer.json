{
    "name": "cgee/php-budget",
    "description": "A self-hosted paycheck budgeting app: recurring paychecks allocated to bills, with email reminders.",
    "type": "project",
    "license": "Apache-2.0",
    "require": {
        "php": ">=8.3",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "phpmailer/phpmailer": "^6.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
